{
  "schemaVersion": 1,
  "id": "mcendgame",
  "version": "${version}",
  "name": "MCEndgame",
  "description": "This is the right outer channel!",
  "authors": [
    "MauCon",
    "Moewe342"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/maucon/MCEndgame-fabric"
  },
  "license": "CC0-1.0",
  "icon": "assets/mcendgame/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "de.fuballer.mcendgame.MCEndgame",
        "adapter": "kotlin"
      }
    ],
    "client": [
      {
        "value": "de.fuballer.client.mcendgame.MCEndgameClient",
        "adapter": "kotlin"
      }
    ],
    "fabric-datagen": [
      {
        "value": "de.fuballer.client.mcendgame.MCEndgameDataGenerator",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "mcendgame.mixins.json",
    {
      "config": "mcendgame.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.13",
    "minecraft": "~1.21.5",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "fantasy": ">=0.6.6",
    "geckolib": ">=5.0"
  }
}